# Staging / Vercel Preview example
# Use isolated staging Supabase and sandbox providers.

NEXT_PUBLIC_APP_URL=https://staging.example.com
JWT_SECRET=staging-long-random-secret
CRON_SECRET=staging-long-random-secret

NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

BLOB_READ_WRITE_TOKEN=your-staging-blob-token

RESEND_API_KEY=your-staging-resend-key
RESEND_FROM_EMAIL=staging@example.com

ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=your-asaas-sandbox-key
ASAAS_WEBHOOK_TOKEN=your-asaas-sandbox-webhook-token


RAPIDOC_API_BASE_URL=https://sandbox.rapidoc.tech/tema
RAPIDOC_CLIENT_ID=your-rapidoc-sandbox-client-id
RAPIDOC_JWT_TOKEN=your-rapidoc-sandbox-token
RAPIDOC_ACCESS_URL=
RAPIDOC_FALLBACK_URL=https://sandbox.rapidoc.tech
NEXT_PUBLIC_RAPIDOC_API_BASE_URL=
