# Environment variables template
# Copy the relevant values to .env.local for local development or configure them in Vercel per environment.
# Never commit real secrets.

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Vercel Blob
BLOB_READ_WRITE_TOKEN=replace-with-vercel-blob-token

# Resend email
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Asaas
ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# Rapidoc
RAPIDOC_API_BASE_URL=https://sandbox.rapidoc.tech/tema
RAPIDOC_CLIENT_ID=
RAPIDOC_JWT_TOKEN=
RAPIDOC_ACCESS_URL=
RAPIDOC_FALLBACK_URL=https://sandbox.rapidoc.tech

# Optional public Rapidoc aliases supported by lib/rapidoc.ts.
# Prefer leaving these empty unless client-side access is really required.
NEXT_PUBLIC_RAPIDOC_API_BASE_URL=
NEXT_PUBLIC_RAPIDOC_FALLBACK_URL=
